mponentId%22%3A%22d874adae-ecc0-4e22-b291-8f844bf68f4f%22%2C%22instanceId%22%3A%2202cba83e-8447-563b-55ed-02a9813f05c4%22%7D%5D" href="/" class="nav-link w-nav-link">Trang chủ</a></div><div class="divider_horizontal"></div><div class="div-block-55 align-right padding-104"><div class="dot-off display-none"></div><a data-wf-native-id-path="02cba83e-8447-563b-55ed-02a9813f05c4:4b5859cd-4859-e24b-571a-4c962ef77ec6" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="4b5859cd-4859-e24b-571a-4c962ef77ec6" data-wf-component-context="%5B%7B%22componentId%22%3A%22d874adae-ecc0-4e22-b291-8f844bf68f4f%22%2C%22instanceId%22%3A%2202cba83e-8447-563b-55ed-02a9813f05c4%22%7D%5D" href="/about" class="nav-link w-nav-link">Giới thiệu</a></div><div class="divider_horizontal"></div><div class="div-block-55 padding-104"><div class="dot-off display-none"></div><a data-wf-native-id-path="02cba83e-8447-563b-55ed-02a9813f05c4:79ae7e77-7d41-ef5b-68e7-7911f0d4ac6e" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="79ae7e77-7d41-ef5b-68e7-7911f0d4ac6e" data-wf-component-context="%5B%7B%22componentId%22%3A%22d874adae-ecc0-4e22-b291-8f844bf68f4f%22%2C%22instanceId%22%3A%2202cba83e-8447-563b-55ed-02a9813f05c4%22%7D%5D" href="/projects" aria-current="page" class="nav-link w-nav-link w--current">Dự Án</a></div><div class="divider_horizontal"></div><div class="div-block-55 padding-104 display-none"><img src="/696db0cd2780ac54df960dfb/697f22865c3f556475c009cc_arrow-up-right.png" loading="lazy" alt="" class="image-18 display-none"/><a data-wf-native-id-path="02cba83e-8447-563b-55ed-02a9813f05c4:c25780ea-61d9-52cb-fbb3-8a578e77a917" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="c25780ea-61d9-52cb-fbb3-8a578e77a917" data-wf-component-context="%5B%7B%22componentId%22%3A%22d874adae-ecc0-4e22-b291-8f844bf68f4f%22%2C%22instanceId%22%3A%2202cba83e-8447-563b-55ed-02a9813f05c4%22%7D%5D" href="/contact" class="nav-link display-none w-nav-link">kết nối ngay</a></div><div class="div-block-53"><a data-wf-native-id-path="02cba83e-8447-563b-55ed-02a9813f05c4:3d2b56cd-6549-1bdb-55f2-c8fc49941ea1" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="3d2b56cd-6549-1bdb-55f2-c8fc49941ea1" data-wf-component-context="%5B%7B%22componentId%22%3A%22d874adae-ecc0-4e22-b291-8f844bf68f4f%22%2C%22instanceId%22%3A%2202cba83e-8447-563b-55ed-02a9813f05c4%22%7D%5D" href="/contact" class="nav-link-copy w-nav-link">kết nối ngay</a><img src="/696db0cd2780ac54df960dfb/697f22865c3f556475c009cc_arrow-up-right.png" loading="lazy" alt="" class="image-18"/></div></nav><a data-wf-native-id-path="02cba83e-8447-563b-55ed-02a9813f05c4:52ac2585-4ad3-b3bc-e66e-6c82eeec27de" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="52ac2585-4ad3-b3bc-e66e-6c82eeec27de" data-wf-component-context="%5B%7B%22componentId%22%3A%22d874adae-ecc0-4e22-b291-8f844bf68f4f%22%2C%22instanceId%22%3A%2202cba83e-8447-563b-55ed-02a9813f05c4%22%7D%5D" href="/" class="brand w-nav-brand"><div class="div-block-51"><img src="/696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo.png" loading="lazy" sizes="(max-width: 1512px) 100vw, 1512px" srcset="/696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo-p-500.png 500w, /696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo-p-800.png 800w, /696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo-p-1080.png 1080w, /696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo.png 1512w" alt="" class="image-16"/></div></a><div class="menu-wrapper w-nav-button"><div data-hover="" role="button" data-menu-button="burger" class="menu-button"><div class="text-block-37">MENU</div><div class="div-block-81"><div class="menu-button-line"></div><div class="menu-button-line"></div><div class="menu-button-line"></div></div></div><div class="icon w-icon-nav-menu"></div></div></div></div><div class="code-embed-4 w-embed w-script"><script src="/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script src="/npm/gsap@3.12.5/dist/CustomEase.min.js"></script>

<script>
gsap.registerPlugin(CustomEase)
CustomEase.create("button-ease", "0.5, 0.05, 0.05, 0.99")

function initMenuButton() {
  // Select elements
  const menuButton = document.querySelector("[data-menu-button]");
  const lines = document.querySelectorAll(".menu-button-line");
  const [line1, line2, line3] = lines;
  
  // Define one global timeline
  let menuButtonTl = gsap.timeline({
    defaults:{
      overwrite:"auto",
      ease: "button-ease",
  	  duration: 0.3
    }
  })

  const menuOpen = () => {
    menuButtonTl.clear() // Stop any previous tweens, if any
    .to(line2, { scaleX: 0, opacity: 0 }) // Step 1: Hide middle line
    .to(line1, { x: "-1.3em", opacity: 0 }, "<") // Step 1: Movetop line
    .to(line3, { x: "1.3em", opacity: 0 }, "<") // Step 1: Move bottom line
    .to([line1,line3],{opacity:0, duration: 0.1},"<+=0.2") // Step 2: Quickly fade top and bottom lines
    .set(line1, { rotate: -135, y: "-1.3em", scaleX: 0.9 }) // Step 3: Instantly rotate and scale top line
    .set(line3, { rotate: 135, y: "-1.4em", scaleX: 0.9 }, "<") // Step 3: Instantly rotate and scale bottom line
    .to(line1, { opacity: 1, x: "0em", y: "0.5em"}) // Step 4: Move top line to final position
    .to(line3, { opacity: 1, x: "0em", y: "-0.25em" }, "<+=0.1"); // Step 4: Move bottom line to final position
  }

  const menuClose = () => {
    menuButtonTl.clear() // Stop any previous tweens, if any
    .to([line1, line2, line3], { // Move all lines back in a different animation
      scaleX: 1,
      rotate: 0,
      x: "0em",
      y: "0em",
      opacity: 1,
      duration: 0.45,
      overwrite: "auto",
    })
  }

  // Toggle Animation
  menuButton.addEventListener("click", () => {
    const currentState = menuButton.getAttribute("data-menu-button");

    if (currentState === "burger") {
      menuOpen()
      menuButton.setAttribute("data-menu-button", "close");
    } else {
      menuClose()
      menuButton.setAttribute("data-menu-button", "burger");
    }
  });
}

// Initialize Burger Menu Button
document.addEventListener('DOMContentLoaded', () => {
  initMenuButton();
});
</script></div></div><div data-animation="default" data-collapse="medium" data-duration="500" data-easing="ease-in" data-easing2="ease-in" role="banner" class="navbar-3-none-homepage w-nav"><div class="navbar-main"><div class="container-4 w-container"><div class="navbar-content-flex"><div class="brand-logo-block"><a data-wf-native-id-path="66d880b6-d62d-b148-5c81-343036b9945e" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="66d880b6-d62d-b148-5c81-343036b9945e" href="/" class="brand-logo-link w-nav-brand"><img src="/696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo.png" loading="lazy" sizes="100vw" srcset="/696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo-p-500.png 500w, /696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo-p-800.png 800w, /696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo-p-1080.png 1080w, /696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo.png 1512w" alt="" class="brand-logo"/></a></div><nav role="navigation" class="nav-menu-3 w-nav-menu"><div class="nav-menu-flex-down"><a href="/" data-w-id="66d880b6-d62d-b148-5c81-343036b99462" data-wf-native-id-path="66d880b6-d62d-b148-5c81-343036b99462" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="66d880b6-d62d-b148-5c81-343036b99462" class="nav-menu-link w-inline-block"><div style="opacity:0" class="nav-menu-dot"></div><div class="nav-text">Trang Chủ</div></a><a data-w-id="66d880b6-d62d-b148-5c81-343036b99466" data-wf-native-id-path="66d880b6-d62d-b148-5c81-343036b99466" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="66d880b6-d62d-b148-5c81-343036b99466" href="/about" class="nav-menu-link w-inline-block"><div style="opacity:0" class="nav-menu-dot"></div><div class="nav-text">Giới Thiệu</div></a><a data-w-id="66d880b6-d62d-b148-5c81-343036b9946a" data-wf-native-id-path="66d880b6-d62d-b148-5c81-343036b9946a" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="66d880b6-d62d-b148-5c81-343036b9946a" href="/projects" aria-current="page" class="nav-menu-link w-inline-block w--current"><div style="opacity:0" class="nav-menu-dot"></div><div class="nav-text">Dự Án</div></a><div class="button-wrap nav-tablet"><a data-wf-native-id-path="66d880b6-d62d-b148-5c81-343036b9946f" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="66d880b6-d62d-b148-5c81-343036b9946f" href="/#contact" class="nav-button w-inline-block"><div class="nav-button-dot"></div><div class="nav-button-text-wrap"><div class="nav-button-text">Contact</div><div class="nav-button-text">Contact</div></div></a></div></div></nav><div class="navbar-button-humber-wrapper"><div class="button-wrap nav"><a data-wf-native-id-path="66d880b6-d62d-b148-5c81-343036b99478" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="66d880b6-d62d-b148-5c81-343036b99478" href="/contact" class="nav-button w-inline-block"><div class="nav-button-dot"></div><div class="nav-button-text-wrap"><div class="nav-button-text">Liên Hệ</div><div class="nav-button-text">Contact</div></div></a></div><div class="nav-menu-button w-nav-button"><div data-w-id="66d880b6-d62d-b148-5c81-343036b99480" data-is-ix2-target="1" class="lottie-animation-3" data-animation-type="lottie" data-src="https://cdn.prod.website-files.com/69f976603849e045838b90f9/69f976653849e045838b9177_Hamburger.lottie" data-loop="0" data-direction="1" data-autoplay="0" data-renderer="svg" data-default-duration="0" data-duration="4.083333333333333" data-loading="eager"></div></div></div></div></div></div></div><div class="page-wrapper"><div class="main-wrapper"><section class="project_section_hero"><div class="w-layout-blockcontainer project_hero-wrapper w-container"><div class="hero-wrapper_headline"><div data-scramble="load" class="text-block-18">Dự án<br/></div><div data-scramble="load" class="text-block-18-copy"> - Tâm huyết</div></div><div data-scramble="load" class="text-block-19">Bộ sưu tập những sản phẩm số được chăm chút tỉ mỉ từ thiết kế đến vận hành.</div></div></section><section class="project_section_content"><div class="w-layout-blockcontainer project_content-wrapper w-container"><div class="tab-bar"><div class="text-block-20">Tất cả</div><div class="text-block-20">thiết kế &amp; phát triển website</div><div class="text-block-20">thiết kế UI-UX</div><div class="text-block-20">nhận diện thương hiệu</div><div class="text-block-20">thiết kế ấn phẩm</div><div class="text-block-20">khác</div></div><div class="w-dyn-list"><div role="list" class="collection-list-3 w-dyn-items w-row"><div role="listitem" class="collection-item-5 w-dyn-item w-col w-col-6"><a data-wf-native-id-path="86eccd07-dae3-e245-e304-ec1ee13d084e_instance-0" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="86eccd07-dae3-e245-e304-ec1ee13d084e" data-wf-cms-context="%5B%7B%22collectionId%22%3A%2269816f59be327836850afe6d%22%2C%22itemId%22%3A%226981775948da74b98ae0c1b0%22%7D%5D" href="/projects/xay-dung-su-hien-dien-chuyen-nghiep-nhung-day-thu-vi-cho-start-up-cong-nghe-dang-len" class="project_content_card-wrapper w-inline-block"><div class="project_content_card"><div class="project_content_headline text-3-lines">Xây dựng sự hiện diện chuyên nghiệp và đầy cảm hứng cho Start-up công nghệ đang lên</div><div class="project_content_thumbnail"><img src="/69816f59b713f65ad8e4f653/6981773e1c8a2356362b5b27_MACBOOK-MOCKUP-02 Large.jpeg" loading="lazy" alt="" sizes="(max-width: 767px) 96vw, (max-width: 991px) 353px, 459px" srcset="/69816f59b713f65ad8e4f653/6981773e1c8a2356362b5b27_MACBOOK-MOCKUP-02 Large-p-500.jpeg 500w, /69816f59b713f65ad8e4f653/6981773e1c8a2356362b5b27_MACBOOK-MOCKUP-02 Large-p-800.jpeg 800w, /69816f59b713f65ad8e4f653/6981773e1c8a2356362b5b27_MACBOOK-MOCKUP-02 Large-p-1080.jpeg 1080w, /69816f59b713f65ad8e4f653/6981773e1c8a2356362b5b27_MACBOOK-MOCKUP-02 Large.jpeg 1280w" class="image-15"/></div><div class="div-block-34"><div class="project_content_discription text-3-lines">The Martec là một nền tảng tiên phong trong việc chuyển hóa dữ liệu nhân sự thành sức mạnh truyền thông, từ đó giúp các thương hiệu lớn xây dựng uy tín và thu hút nhân tài bằng những nội dung chân thực, được cá nhân hóa một cách thông minh. </div><div class="tag-wrapper"><div class="tag">Thiết kế website</div><div class="tag">phát triển website</div><div class="tag">thiết kế web app</div><div class="tag">tư vấn thiết kế</div></div></div></div></a></div><div role="listitem" class="collection-item-5 w-dyn-item w-col w-col-6"><a data-wf-native-id-path="86eccd07-dae3-e245-e304-ec1ee13d084e_instance-1" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="86eccd07-dae3-e245-e304-ec1ee13d084e" data-wf-cms-context="%5B%7B%22collectionId%22%3A%2269816f59be327836850afe6d%22%2C%22itemId%22%3A%226981761ed8826fd265b3007d%22%7D%5D" href="/projects/goi-tron-net-sang-trong-cua-khach-san-boutique-vao-mot-khong-gian-so-day-tinh-te" class="project_content_card-wrapper w-inline-block"><div class="project_content_card"><div class="project_content_headline text-3-lines">Gói trọn nét sang trọng của khách sạn Boutique vào một không gian số đầy tinh tế</div><div class="project_content_thumbnail"><img src="/69816f59b713f65ad8e4f653/698175c3fb6588fd9bc98faf_homepage Large.jpeg" loading="lazy" alt="" sizes="(max-width: 767px) 96vw, (max-width: 991px) 353px, 459px" srcset="/69816f59b713f65ad8e4f653/698175c3fb6588fd9bc98faf_homepage Large-p-500.jpeg 500w, /69816f59b713f65ad8e4f653/698175c3fb6588fd9bc98faf_homepage Large-p-800.jpeg 800w, /69816f59b713f65ad8e4f653/698175c3fb6588fd9bc98faf_homepage Large-p-1080.jpeg 1080w, /69816f59b713f65ad8e4f653/698175c3fb6588fd9bc98faf_homepage Large.jpeg 1280w" class="image-15"/></div><div class="div-block-34"><div class="project_content_discription text-3-lines">Tọa lạc tại vị trí đắc địa nơi trái tim phố cổ Hà Nội, Manevi Premier Boutique Hotel hiện diện như một biểu tượng của sự giao thoa tinh tế giữa nét quyến rũ cổ điển đặc trưng của di sản và hơi thở sang trọng, phóng khoáng của thời đại mới. Dự án thiết kế website của chúng tôi hướng tới việc số hóa trải nghiệm cao cấp này, mang đến trải nghiệm trực tuyến liền mạch và đẳng cấp cho tệp khách hàng tinh hoa của doanh nghiệp.</div><div class="tag-wrapper"><div class="tag">Thiết kế website</div><div class="tag">phát triển website</div><div class="tag">thiết kế UI-UX</div><div class="tag">tư vấn thiết kế</div></div></div></div></a></div><div role="listitem" class="collection-item-5 w-dyn-item w-col w-col-6"><a data-wf-native-id-path="86eccd07-dae3-e245-e304-ec1ee13d084e_instance-2" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="86eccd07-dae3-e245-e304-ec1ee13d084e" data-wf-cms-context="%5B%7B%22collectionId%22%3A%2269816f59be327836850afe6d%22%2C%22itemId%22%3A%22698170062524dd0fbcc39cd8%22%7D%5D" href="/projects/dinh-hinh-dien-mao-truc-tuyen-cho-doi-ngu-van-hanh-homestay-dang-tren-da-but-pha" class="project_content_card-wrapper w-inline-block"><div class="project_content_card"><div class="project_content_headline text-3-lines">Định hình diện mạo trực tuyến cho đội ngũ vận hành homestay đang trên đà bứt phá</div><div class="project_content_thumbnail"><img src="/69816f59b713f65ad8e4f653/69816fd20439e19d6ba0dfaa_IPHONE-MOCKUP-06 Large.jpeg" loading="lazy" alt="" sizes="(max-width: 767px) 96vw, (max-width: 991px) 353px, 459px" srcset="/69816f59b713f65ad8e4f653/69816fd20439e19d6ba0dfaa_IPHONE-MOCKUP-06 Large-p-500.jpeg 500w, /69816f59b713f65ad8e4f653/69816fd20439e19d6ba0dfaa_IPHONE-MOCKUP-06 Large-p-800.jpeg 800w, /69816f59b713f65ad8e4f653/69816fd20439e19d6ba0dfaa_IPHONE-MOCKUP-06 Large-p-1080.jpeg 1080w, /69816f59b713f65ad8e4f653/69816fd20439e19d6ba0dfaa_IPHONE-MOCKUP-06 Large.jpeg 1280w" class="image-15"/></div><div class="div-block-34"><div class="project_content_discription text-3-lines">S.Sens Homes là một chuỗi căn hộ mô hình Short-term Rental (lưu trú ngắn hạn) bắt đầu với một cơ sở tại Hà Nội vào năm 2015. Đến nay hệ thống chuỗi căn hộ của S.Sens đã lên tới con số trên 40 căn hộ, trải rộng khắp 5 thành phố lớn tại Việt Nam. Để S.Sens có thể truyền tải mục tiêu thương hiệu đó là “Thiết kế riêng biệt giúp bạn trải nghiệm nhịp sống thành phố một cách chân thực và thoải mái nhất, nơi lưu giữ những kỷ niệm đẹp trong suốt kỳ nghỉ của bạn” trên môi trường Digital tốt hơn, chúng tôi đã giúp S.Sens định hướng hình ảnh và xây dựng website của mình.</div><div class="tag-wrapper"><div class="tag">Thiết kế website</div><div class="tag">phát triển website</div><div class="tag">thiết kế UI-UX</div><div class="tag">tư vấn thiết kế</div></div></div></div></a></div></div></div></div><div class="padding-section-120"></div></section></div></div><section class="footer"><div class="carousel-wrapper"><div class="carousel"><div class="div-block-19"><div class="text-block-8">INSPIRE<br/></div><img src="data:image/png;base64," alt="Right" class="img"/><div class="text-block-8">DELIVERY</div><img src="data:image/png;base64," alt="Right" class="img"/></div><div class="div-block-19"><div class="text-block-8">CREATE<br/></div><img src="data:image/png;base64," alt="Right" class="img"/><div class="text-block-8">INSPIRE<br/></div><img src="data:image/png;base64," alt="Right" class="img"/></div><div class="div-block-19"><div class="text-block-8">DELIVERY</div><img src="data:image/png;base64," alt="Right" class="img"/><div class="text-block-8">CREATE</div><img src="data:image/png;base64," alt="Right" class="img"/></div></div><div class="carousel"><div class="div-block-19"><div class="text-block-8">INSPIRE<br/></div><img src="data:image/png;base64," alt="Right" class="img"/><div class="text-block-8">DELIVERY</div><img src="data:image/png;base64," alt="Right" class="img"/></div><div class="div-block-19"><div class="text-block-8">CREATE<br/></div><img src="data:image/png;base64," alt="Right" class="img"/><div class="text-block-8">INSPIRE<br/></div><img src="data:image/png;base64," alt="Right" class="img"/></div><div class="div-block-19"><div class="text-block-8">DELIVERY</div><img src="data:image/png;base64," alt="Ri