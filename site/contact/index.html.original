v class="div-block-53"><a data-wf-native-id-path="4c7736e7-ffa4-e2fd-3497-d81e9ed39e05:3d2b56cd-6549-1bdb-55f2-c8fc49941ea1" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="3d2b56cd-6549-1bdb-55f2-c8fc49941ea1" data-wf-component-context="%5B%7B%22componentId%22%3A%22d874adae-ecc0-4e22-b291-8f844bf68f4f%22%2C%22instanceId%22%3A%224c7736e7-ffa4-e2fd-3497-d81e9ed39e05%22%7D%5D" href="/contact" aria-current="page" class="nav-link-copy w-nav-link w--current">kết nối ngay</a><img src="/696db0cd2780ac54df960dfb/697f22865c3f556475c009cc_arrow-up-right.png" loading="lazy" alt="" class="image-18"/></div></nav><a data-wf-native-id-path="4c7736e7-ffa4-e2fd-3497-d81e9ed39e05:52ac2585-4ad3-b3bc-e66e-6c82eeec27de" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="52ac2585-4ad3-b3bc-e66e-6c82eeec27de" data-wf-component-context="%5B%7B%22componentId%22%3A%22d874adae-ecc0-4e22-b291-8f844bf68f4f%22%2C%22instanceId%22%3A%224c7736e7-ffa4-e2fd-3497-d81e9ed39e05%22%7D%5D" href="/" class="brand w-nav-brand"><div class="div-block-51"><img src="/696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo.png" loading="lazy" sizes="(max-width: 1512px) 100vw, 1512px" srcset="/696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo-p-500.png 500w, /696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo-p-800.png 800w, /696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo-p-1080.png 1080w, /696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo.png 1512w" alt="" class="image-16"/></div></a><div class="menu-wrapper w-nav-button"><div data-hover="" role="button" data-menu-button="burger" class="menu-button"><div class="text-block-37">MENU</div><div class="div-block-81"><div class="menu-button-line"></div><div class="menu-button-line"></div><div class="menu-button-line"></div></div></div><div class="icon w-icon-nav-menu"></div></div></div></div><div class="code-embed-4 w-embed w-script"><script src="/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script src="/npm/gsap@3.12.5/dist/CustomEase.min.js"></script>

<script>
gsap.registerPlugin(CustomEase)
CustomEase.create("button-ease", "0.5, 0.05, 0.05, 0.99")

function initMenuButton() {
  // Select elements
  const menuButton = document.querySelector("[data-menu-button]");
  const lines = document.querySelectorAll(".menu-button-line");
  const [line1, line2, line3] = lines;
  
  // Define one global timeline
  let menuButtonTl = gsap.timeline({
    defaults:{
      overwrite:"auto",
      ease: "button-ease",
  	  duration: 0.3
    }
  })

  const menuOpen = () => {
    menuButtonTl.clear() // Stop any previous tweens, if any
    .to(line2, { scaleX: 0, opacity: 0 }) // Step 1: Hide middle line
    .to(line1, { x: "-1.3em", opacity: 0 }, "<") // Step 1: Movetop line
    .to(line3, { x: "1.3em", opacity: 0 }, "<") // Step 1: Move bottom line
    .to([line1,line3],{opacity:0, duration: 0.1},"<+=0.2") // Step 2: Quickly fade top and bottom lines
    .set(line1, { rotate: -135, y: "-1.3em", scaleX: 0.9 }) // Step 3: Instantly rotate and scale top line
    .set(line3, { rotate: 135, y: "-1.4em", scaleX: 0.9 }, "<") // Step 3: Instantly rotate and scale bottom line
    .to(line1, { opacity: 1, x: "0em", y: "0.5em"}) // Step 4: Move top line to final position
    .to(line3, { opacity: 1, x: "0em", y: "-0.25em" }, "<+=0.1"); // Step 4: Move bottom line to final position
  }

  const menuClose = () => {
    menuButtonTl.clear() // Stop any previous tweens, if any
    .to([line1, line2, line3], { // Move all lines back in a different animation
      scaleX: 1,
      rotate: 0,
      x: "0em",
      y: "0em",
      opacity: 1,
      duration: 0.45,
      overwrite: "auto",
    })
  }

  // Toggle Animation
  menuButton.addEventListener("click", () => {
    const currentState = menuButton.getAttribute("data-menu-button");

    if (currentState === "burger") {
      menuOpen()
      menuButton.setAttribute("data-menu-button", "close");
    } else {
      menuClose()
      menuButton.setAttribute("data-menu-button", "burger");
    }
  });
}

// Initialize Burger Menu Button
document.addEventListener('DOMContentLoaded', () => {
  initMenuButton();
});
</script></div></div><div data-animation="default" data-collapse="medium" data-duration="500" data-easing="ease-in" data-easing2="ease-in" role="banner" class="navbar-3-none-homepage w-nav"><div class="navbar-main"><div class="container-4 w-container"><div class="navbar-content-flex"><div class="brand-logo-block"><a data-wf-native-id-path="521136eb-a020-9d88-2e83-b4f750644239" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="521136eb-a020-9d88-2e83-b4f750644239" href="/" class="brand-logo-link w-nav-brand"><img src="/696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo.png" loading="lazy" sizes="(max-width: 479px) 96vw, 235px" srcset="/696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo-p-500.png 500w, /696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo-p-800.png 800w, /696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo-p-1080.png 1080w, /696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo.png 1512w" alt="" class="brand-logo"/></a></div><nav role="navigation" class="nav-menu-3 w-nav-menu"><div class="nav-menu-flex-down"><a href="/" data-w-id="521136eb-a020-9d88-2e83-b4f75064423d" data-wf-native-id-path="521136eb-a020-9d88-2e83-b4f75064423d" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="521136eb-a020-9d88-2e83-b4f75064423d" class="nav-menu-link w-inline-block"><div style="opacity:0" class="nav-menu-dot"></div><div class="nav-text">Trang Chủ</div></a><a data-w-id="521136eb-a020-9d88-2e83-b4f750644241" data-wf-native-id-path="521136eb-a020-9d88-2e83-b4f750644241" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="521136eb-a020-9d88-2e83-b4f750644241" href="/about" class="nav-menu-link w-inline-block"><div style="opacity:0" class="nav-menu-dot"></div><div class="nav-text">Giới Thiệu</div></a><a data-w-id="521136eb-a020-9d88-2e83-b4f750644245" data-wf-native-id-path="521136eb-a020-9d88-2e83-b4f750644245" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="521136eb-a020-9d88-2e83-b4f750644245" href=