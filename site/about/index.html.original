mponentId%22%3A%22d874adae-ecc0-4e22-b291-8f844bf68f4f%22%2C%22instanceId%22%3A%225c5514db-c6c1-4281-ccaa-641750220d8a%22%7D%5D" href="/" class="nav-link w-nav-link">Trang chủ</a></div><div class="divider_horizontal"></div><div class="div-block-55 align-right padding-104"><div class="dot-off display-none"></div><a data-wf-native-id-path="5c5514db-c6c1-4281-ccaa-641750220d8a:4b5859cd-4859-e24b-571a-4c962ef77ec6" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="4b5859cd-4859-e24b-571a-4c962ef77ec6" data-wf-component-context="%5B%7B%22componentId%22%3A%22d874adae-ecc0-4e22-b291-8f844bf68f4f%22%2C%22instanceId%22%3A%225c5514db-c6c1-4281-ccaa-641750220d8a%22%7D%5D" href="/about" aria-current="page" class="nav-link w-nav-link w--current">Giới thiệu</a></div><div class="divider_horizontal"></div><div class="div-block-55 padding-104"><div class="dot-off display-none"></div><a data-wf-native-id-path="5c5514db-c6c1-4281-ccaa-641750220d8a:79ae7e77-7d41-ef5b-68e7-7911f0d4ac6e" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="79ae7e77-7d41-ef5b-68e7-7911f0d4ac6e" data-wf-component-context="%5B%7B%22componentId%22%3A%22d874adae-ecc0-4e22-b291-8f844bf68f4f%22%2C%22instanceId%22%3A%225c5514db-c6c1-4281-ccaa-641750220d8a%22%7D%5D" href="/projects" class="nav-link w-nav-link">Dự Án</a></div><div class="divider_horizontal"></div><div class="div-block-55 padding-104 display-none"><img src="/696db0cd2780ac54df960dfb/697f22865c3f556475c009cc_arrow-up-right.png" loading="lazy" alt="" class="image-18 display-none"/><a data-wf-native-id-path="5c5514db-c6c1-4281-ccaa-641750220d8a:c25780ea-61d9-52cb-fbb3-8a578e77a917" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="c25780ea-61d9-52cb-fbb3-8a578e77a917" data-wf-component-context="%5B%7B%22componentId%22%3A%22d874adae-ecc0-4e22-b291-8f844bf68f4f%22%2C%22instanceId%22%3A%225c5514db-c6c1-4281-ccaa-641750220d8a%22%7D%5D" href="/contact" class="nav-link display-none w-nav-link">kết nối ngay</a></div><div class="div-block-53"><a data-wf-native-id-path="5c5514db-c6c1-4281-ccaa-641750220d8a:3d2b56cd-6549-1bdb-55f2-c8fc49941ea1" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="3d2b56cd-6549-1bdb-55f2-c8fc49941ea1" data-wf-component-context="%5B%7B%22componentId%22%3A%22d874adae-ecc0-4e22-b291-8f844bf68f4f%22%2C%22instanceId%22%3A%225c5514db-c6c1-4281-ccaa-641750220d8a%22%7D%5D" href="/contact" class="nav-link-copy w-nav-link">kết nối ngay</a><img src="/696db0cd2780ac54df960dfb/697f22865c3f556475c009cc_arrow-up-right.png" loading="lazy" alt="" class="image-18"/></div></nav><a data-wf-native-id-path="5c5514db-c6c1-4281-ccaa-641750220d8a:52ac2585-4ad3-b3bc-e66e-6c82eeec27de" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="52ac2585-4ad3-b3bc-e66e-6c82eeec27de" data-wf-component-context="%5B%7B%22componentId%22%3A%22d874adae-ecc0-4e22-b291-8f844bf68f4f%22%2C%22instanceId%22%3A%225c5514db-c6c1-4281-ccaa-641750220d8a%22%7D%5D" href="/" class="brand w-nav-brand"><div class="div-block-51"><img src="/696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo.png" loading="lazy" sizes="(max-width: 1512px) 100vw, 1512px" srcset="/696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo-p-500.png 500w, /696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo-p-800.png 800w, /696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo-p-1080.png 1080w, /696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo.png 1512w" alt="" class="image-16"/></div></a><div class="menu-wrapper w-nav-button"><div data-hover="" role="button" data-menu-button="burger" class="menu-button"><div class="text-block-37">MENU</div><div class="div-block-81"><div class="menu-button-line"></div><div class="menu-button-line"></div><div class="menu-button-line"></div></div></div><div class="icon w-icon-nav-menu"></div></div></div></div><div class="code-embed-4 w-embed w-script"><script src="/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script src="/npm/gsap@3.12.5/dist/CustomEase.min.js"></script>

<script>
gsap.registerPlugin(CustomEase)
CustomEase.create("button-ease", "0.5, 0.05, 0.05, 0.99")

function initMenuButton() {
  // Select elements
  const menuButton = document.querySelector("[data-menu-button]");
  const lines = document.querySelectorAll(".menu-button-line");
  const [line1, line2, line3] = lines;
  
  // Define one global timeline
  let menuButtonTl = gsap.timeline({
    defaults:{
      overwrite:"auto",
      ease: "button-ease",
  	  duration: 0.3
    }
  })

  const menuOpen = () => {
    menuButtonTl.clear() // Stop any previous tweens, if any
    .to(line2, { scaleX: 0, opacity: 0 }) // Step 1: Hide middle line
    .to(line1, { x: "-1.3em", opacity: 0 }, "<") // Step 1: Movetop line
    .to(line3, { x: "1.3em", opacity: 0 }, "<") // Step 1: Move bottom line
    .to([line1,line3],{opacity:0, duration: 0.1},"<+=0.2") // Step 2: Quickly fade top and bottom lines
    .set(line1, { rotate: -135, y: "-1.3em", scaleX: 0.9 }) // Step 3: Instantly rotate and scale top line
    .set(line3, { rotate: 135, y: "-1.4em", scaleX: 0.9 }, "<") // Step 3: Instantly rotate and scale bottom line
    .to(line1, { opacity: 1, x: "0em", y: "0.5em"}) // Step 4: Move top line to final position
    .to(line3, { opacity: 1, x: "0em", y: "-0.25em" }, "<+=0.1"); // Step 4: Move bottom line to final position
  }

  const menuClose = () => {
    menuButtonTl.clear() // Stop any previous tweens, if any
    .to([line1, line2, line3], { // Move all lines back in a different animation
      scaleX: 1,
      rotate: 0,
      x: "0em",
      y: "0em",
      opacity: 1,
      duration: 0.45,
      overwrite: "auto",
    })
  }

  // Toggle Animation
  menuButton.addEventListener("click", () => {
    const currentState = menuButton.getAttribute("data-menu-button");

    if (currentState === "burger") {
      menuOpen()
      menuButton.setAttribute("data-menu-button", "close");
    } else {
      menuClose()
      menuButton.setAttribute("data-menu-button", "burger");
    }
  });
}

// Initialize Burger Menu Button
document.addEventListener('DOMContentLoaded', () => {
  initMenuButton();
});
</script></div></div><div data-animation="default" data-collapse="medium" data-duration="500" data-easing="ease-in" data-easing2="ease-in" role="banner" class="navbar-3-none-homepage w-nav"><div class="navbar-main"><div class="container-4 w-container"><div class="navbar-content-flex"><div class="brand-logo-block"><a data-wf-native-id-path="51990e0f-cd5f-2e6a-efc0-bd910456a6b5" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="51990e0f-cd5f-2e6a-efc0-bd910456a6b5" href="/" class="brand-logo-link w-nav-brand"><img src="/696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo.png" loading="lazy" sizes="(max-width: 1512px) 100vw, 1512px" srcset="/696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo-p-500.png 500w, /696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo-p-800.png 800w, /696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo-p-1080.png 1080w, /696db0cd2780ac54df960dfb/6980836a3b2ecebdfb7ef106_logo.png 1512w" alt="" class="brand-logo"/></a></div><nav role="navigation" class="nav-menu-3 w-nav-menu"><div class="nav-menu-flex-down"><a href="/" data-w-id="51990e0f-cd5f-2e6a-efc0-bd910456a6b9" data-wf-native-id-path="51990e0f-cd5f-2e6a-efc0-bd910456a6b9" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="51990e0f-cd5f-2e6a-efc0-bd910456a6b9" class="nav-menu-link w-inline-block"><div style="opacity:0" class="nav-menu-dot"></div><div class="nav-text">Trang Chủ</div></a><a data-w-id="51990e0f-cd5f-2e6a-efc0-bd910456a6bd" data-wf-native-id-path="51990e0f-cd5f-2e6a-efc0-bd910456a6bd" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="51990e0f-cd5f-2e6a-efc0-bd910456a6bd" href="/about" aria-current="page" class="nav-menu-link w-inline-block w--current"><div style="opacity:0" class="nav-menu-dot"></div><div class="nav-text">Giới Thiệu</div></a><a data-w-id="51990e0f-cd5f-2e6a-efc0-bd910456a6c1" data-wf-native-id-path="51990e0f-cd5f-2e6a-efc0-bd910456a6c1" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="51990e0f-cd5f-2e6a-efc0-bd910456a6c1" href="/projects" class="nav-menu-link w-inline-block"><div style="opacity:0" class="nav-menu-dot"></div><div class="nav-text">Dự Án</div></a><div class="button-wrap nav-tablet"><a data-wf-native-id-path="51990e0f-cd5f-2e6a-efc0-bd910456a6c6" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="51990e0f-cd5f-2e6a-efc0-bd910456a6c6" href="/#contact" class="nav-button w-inline-block"><div class="nav-button-dot"></div><div class="nav-button-text-wrap"><div class="nav-button-text">Contact</div><div class="nav-button-text">Contact</div></div></a></div></div></nav><div class="navbar-button-humber-wrapper"><div class="button-wrap nav"><a data-wf-native-id-path="51990e0f-cd5f-2e6a-efc0-bd910456a6cf" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="51990e0f-cd5f-2e6a-efc0-bd910456a6cf" href="/contact" class="nav-button w-inline-block"><div class="nav-button-dot"></div><div class="nav-button-text-wrap"><div class="nav-button-text">Liên Hệ</div><div class="nav-button-text">Contact</div></div></a></div><div class="nav-menu-button w-nav-button"><div data-w-id="51990e0f-cd5f-2e6a-efc0-bd910456a6d7" data-is-ix2-target="1" class="lottie-animation-3" data-animation-type="lottie" data-src="https://cdn.prod.website-files.com/69f976603849e045838b90f9/69f976653849e045838b9177_Hamburger.lottie" data-loop="0" data-direction="1" data-autoplay="0" data-renderer="svg" data-default-duration="0" data-duration="4.083333333333333" data-loading="eager"></div></div></div></div></div></div></div><div class="page-wrapper"><div class="main-wrapper"><section class="about_section_hero"><div class="about_hero_component"><div data-scramble="load" class="about_hero_headline">Kiến tạo trải nghiệm số thực sự đáng nhớ</div><div data-pixelate-render-trigger="inview" data-pixelate-render="" class="about_hero_image-wrapper"><img class="image-19" src="/696db0cd2780ac54df960dfb/69898c98624326ab55c89d9b_Rectangle 147.webp" alt="" data-pixelate-render-img="" sizes="100vw" loading="lazy" srcset="/696db0cd2780ac54df960dfb/69898c98624326ab55c89d9b_Rectangle 147-p-500.webp 500w, /696db0cd2780ac54df960dfb/69898c98624326ab55c89d9b_Rectangle 147-p-800.webp 800w, /696db0cd2780ac54df960dfb/69898c98624326ab55c89d9b_Rectangle 147-p-1080.webp 1080w, /696db0cd2780ac54df960dfb/69898c98624326ab55c89d9b_Rectangle 147.webp 1227w"/></div></div></section><section class="about_section_introduction"><div class="padding-section-72"></div><div class="about_introduction_wrapper"><div class="button-text-wrapper"><div class="dot-on"></div><div class="label-text">mục tiêu</div></div><div class="text-block-25">Trong gần một thập kỉ làm việc trong ngành thiết kế sáng tạo, chúng tôi chúng kiến một thị trường đang dần bão hòa bởi những cam kết thiếu chiều sâu và các giải pháp chưa tương xứng với kỳ vọng, chúng tôi thấu hiểu rằng khách hàng chính là đối tượng phải đối mặt với nhiều rủi ro nhất. Dao.design được ra đời với mong muốn phá bỏ rào cản đó.</div><div class="text-block-25">Lấy sự tử tế và uy tín làm tôn chỉ hoạt động, chúng tôi cam kết mang lại những giá trị thiết kế thực thụ. Bằng việc kết hợp chặt chẽ giữa quy trình minh bạch, tư duy thiết kế lấy người dùng làm trung tâm và sức mạnh công nghệ từ các giải pháp low-code hiện đại, chúng tôi khẳng định trách nhiệm trong việc bảo vệ tối đa lợi ích và ngân sách của khách hàng. Tại đây, niềm tin của bạn không chỉ là mục tiêu, mà là nền tảng cho mọi giải pháp mà chúng tôi kiến tạo.</div></div><div class="padding-section-72"></div></section><section class="about_section_services"><div class="about_services-wrapper"><div class="button-text-wrapper"><div class="dot-on"></div><div class="label-text">dịch vụ</div></div><div class="about_service_component-wrapper"><div class="about_service_component"><div class="divider_horizontal"></div><div class="about_services_dropdown-wrapper"><div class="text-block-29">thiết kế website</div><div class="lottie-animation" data-w-id="dafa42ab-d4da-5294-a5b8-a6e7ba87ad44" data-animation-type="lottie" data-src="https://cdn.prod.website-files.com/696db0cd2780ac54df960dfb/6989940695d84fde9f173a53_lottieflow-dropdown-01-ffffff-easey.json" data-loop="0" data-direction="1" data-autoplay="1" data-is-ix2-target="0" data-renderer="svg" data-default-duration="0" data-duration="1.28" data-loading="eager"></div></div><div class="about_services_card-wrapper"><div class="about_services_content-wrapper"><div class="div-block-60"><div class="text-block-27">Chúng tôi tập trung vào việc tạo ra những trải nghiệm số trực quan, lôi cuốn và lấy người dùng làm trung tâm nhằm mang lại hiệu quả thiết thực cho doanh nghiệp.</div><div class="text-block-28">→ Nghiên cứu &amp; Định hướng<br/>→ Art direction<br/>→ Story telling <br/>→ Thiết kế Wireframe<br/>→ Thiết kế Giao diện UI-UX <br/>→ Design system<br/>→ Landing page</div></div><div class="div-block-58"><img src="/696db0cd2780ac54df960dfb/697ad32671b14251b0e34dfc_IPHONE-MOCKUP-06 Large.jpeg" loading="lazy" sizes="(max-width: 1279px) 100vw, 1280px" srcset="/696db0cd2780ac54df960dfb/697ad32671b14251b0e34dfc_IPHONE-MOCKUP-06 Large-p-500.jpeg 500w, /696db0cd2780ac54df960dfb/697ad32671b14251b0e34dfc_IPHONE-MOCKUP-06 Large-p-800.jpeg 800w, /696db0cd2780ac54df960dfb/697ad32671b14251b0e34dfc_IPHONE-MOCKUP-06 Large-p-1080.jpeg 1080w, /696db0cd2780ac54df960dfb/697ad32671b14251b0e34dfc_IPHONE-MOCKUP-06 Large.jpeg 1280w" alt="" class="image-20"/></div></div><a data-wf-native-id-path="ee7f5f72-fb3f-fc11-4ce0-c1f28f6522d6:07479fc5-d9ef-138a-3532-2f8481d3a1d1" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="07479fc5-d9ef-138a-3532-2f8481d3a1d1" data-wf-component-context="%5B%7B%22componentId%22%3A%2207479fc5-d9ef-138a-3532-2f8481d3a1d1%22%2C%22instanceId%22%3A%22ee7f5f72-fb3f-fc11-4ce0-c1f28f6522d6%22%7D%5D" href="/projects" class="button-secondary w-button">xem dự án</a></div></div><div class="about_service_component"><div class="divider_horizontal"></div><div class="about_services_dropdown-wrapper"><div class="text-block-29">Phát triển website</div><div class="lottie-animation" data-w-id="3a519a31-601b-957d-6761-9ec902145a1a" data-animation-type="lottie" data-src="https://cdn.prod.website-files.com/696db0cd2780ac54df960dfb/6989940695d84fde9f173a53_lottieflow-dropdown-01-ffffff-easey.json" data-loop="0" data-direction="1" data-autoplay="1" data-is-ix2-target="0" data-renderer="svg" data-default-duration="0" data-duration="1.28" data-loading="eager"></div></div><div class="about_services_card-wrapper"><div class="about_services_content-wrapper"><div class="div-block-60"><div class="text-block-27">Giúp doanh nghiệp chuyển hóa các ý tưởng thành những giải pháp số chất lượng cao.</div><div class="text-block-28">→ Webflow Development <br/>→ Giải pháp CMS <br/>→ Tối ưu SEO <br/>→ Bảo trì &amp; Cập nhật<br/></div></div><div class="div-block-58"><img src="/696db0cd2780ac54df960dfb/697ad32634339b29eb2864ca_MACBOOK-MOCKUP-01 Large.jpeg" loading="lazy" sizes="(max-width: 1279px) 100vw, 1280px" srcset="/696db0cd2780ac54df960dfb/697ad32634339b29eb2864ca_MACBOOK-MOCKUP-01 Large-p-500.jpeg 500w, /696db0cd2780ac54df960dfb/697ad32634339b29eb2864ca_MACBOOK-MOCKUP-01 Large-p-800.jpeg 800w, /696db0cd2780ac54df960dfb/697ad32634339b29eb2864ca_MACBOOK-MOCKUP-01 Large-p-1080.jpeg 1080w, /696db0cd2780ac54df960dfb/697ad32634339b29eb2864ca_MACBOOK-MOCKUP-01 Large.jpeg 1280w" alt="" class="image-20"/></div></div><a data-wf-native-id-path="3a519a31-601b-957d-6761-9ec902145a32:07479fc5-d9ef-138a-3532-2f8481d3a1d1" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="07479fc5-d9ef-138a-3532-2f8481d3a1d1" data-wf-component-context="%5B%7B%22componentId%22%3A%2207479fc5-d9ef-138a-3532-2f8481d3a1d1%22%2C%22instanceId%22%3A%223a519a31-601b-957d-6761-9ec902145a32%22%7D%5D" href="/projects" class="button-secondary w-button">xem dự án</a></div></div><div class="about_service_component"><div class="divider_horizontal"></div><div class="about_services_dropdown-wrapper"><div class="text-block-29">nhận diện thương hiệu</div><div class="lottie-animation" data-w-id="4f993b94-8fe1-c44b-3fb5-e8800ab371d1" data-animation-type="lottie" data-src="https://cdn.prod.website-files.com/696db0cd2780ac54df960dfb/6989940695d84fde9f173a53_lottieflow-dropdown-01-ffffff-easey.json" data-loop="0" data-direction="1" data-autoplay="1" data-is-ix2-target="0" data-renderer="svg" data-default-duration="0" data-duration="1.28" data-loading="eager"></div></div><div class="about_services_card-wrapper"><div class="about_services_content-wrapper"><div class="div-block-60"><div class="text-block-27">Cùng doanh nghiệp xây dựng một thương hiệu khác biệt, đáng nhớ và nhất quán. Từ đó tạo nên sự kết nối sâu sắc với khách hàng mục tiêu.</div><div class="text-block-28">→ Định vị cốt lõi <br/>→ Định hướng thiết kế<br/>→ Logo độc bản<br/>→ Font chữ &amp; Hệ màu<br/>→ Ứng dụng văn phòng<br/>→ Brand Guidelines<br/></div></div><div class="div-block-58"><img src="/696db0cd2780ac54df960dfb/697ad3269589cae206db3d27_MACBOOK-MOCKUP-010 Large.jpeg" loading="lazy" sizes="100vw" srcset="/696db0cd2780ac54df960dfb/697ad3269589cae206db3d27_MACBOOK-MOCKUP-010 Large-p-500.jpeg 500w, /696db0cd2780ac54df960dfb/697ad3269589cae206db3d27_MACBOOK-MOCKUP-010 Large-p-800.jpeg 800w, /696db0cd2780ac54df960dfb/697ad3269589cae206db3d27_MACBOOK-MOCKUP-010 Large.jpeg 854w" alt="" class="image-20"/></div></div><a data-wf-native-id-path="4f993b94-8fe1-c44b-3fb5-e8800ab371e9:07479fc5-d9ef-138a-3532-2f8481d3a1d1" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="07479fc5-d9ef-138a-3532-2f8481d3a1d1" data-wf-component-context="%5B%7B%22componentId%22%3A%2207479fc5-d9ef-138a-3532-2f8481d3a1d1%22%2C%22instanceId%22%3A%224f993b94-8fe1-c44b-3fb5-e8800ab371e9%22%7D%5D" href="/projects" class="button-secondary w-button">xem dự án</a></div></div></div></div></section><section class="about_section_process"><div class="padding-section-120"></div><div class="about_process-wrapper"><div class="about_process_headline-wrapper"><div class="button-text-wrapper"><div class="dot-on"></div><div class="label-text">quy trình thiết kế</div></div></div><div class="about_process_card-wrapper"><div class="process_card_component-wrapper"><div class="div-block-61"><img src="/696db0cd2780ac54df960dfb/69899e6eafbb1d9cf4a75253_Rectangle 148.png" loading="lazy" alt="" class="image-21"/></div><div class="process_card_tittle-wrapper"><div class="card_tittle_number">1</div><div class="card_tittle_text">Khám phá &amp; Định hình</div></div><div class="process_card_content">Chúng tôi bắt đầu bằng việc lắng nghe sâu sắc — thấu hiểu tầm nhìn, những thách thức, đối tượng khách hàng và mục tiêu của bạn. Thông qua nghiên cứu, các buổi thảo luận (workshops) và những phân tích đối thủ, chúng tôi định hình một nền tảng vững chắc cho mọi bước tiếp theo.</div></div><div class="process_card_component-wrapper"><div class="div-block-61"><img src="/696db0cd2780ac54df960dfb/69899e36f037781ffb293840_photo-1581291518857-4e27b48ff24e.avif" loading="lazy" alt="" class="image-21"/></div><div class="process_card_tittle-wrapper"><div class="card_tittle_number">2</div><div class="card_tittle_text">Thiết kế &amp; tinh chỉnh</div></div><div class="process_card_content">Khi mọi thứ đã rõ ràng, chúng tôi xây dựng khung chiến lược từ cấu trúc website đến luồng người dùng để đảm bảo sự giao thoa giữa hình thức và công năng. Sau đó chuyển hóa thành giao diện trực quan (high-fidelity) với hệ thống thành phần linh hoạt, được tối ưu liên tục để đảm bảo tính đồng nhất giữa thiết kế và thương hiệu.</div></div><div class="process_card_component-wrapper"><div class="div-block-61"><img src="/696db0cd2780ac54df960dfb/6989c0107f235ca5583fa3ce_Rectangle 150.png" loading="lazy" alt="" class="image-21"/></div><div class="process_card_tittle-wrapper"><div class="card_tittle_number">3</div><div class="card_tittle_text">Kiểm thử &amp; Triển khai</div></div><div class="process_card_content">Sau khi hoàn thiện thiết kế tổng thể là lúc sản phẩm được lập trình, tinh chỉnh và kiểm thử kỹ lưỡng nhằm mang lại một giải pháp số hoàn chỉnh và sẵn sàng vận hành.</div></div><div class="process_card_component-wrapper"><div class="div-block-61"><img src="/696db0cd2780ac54df960dfb/6989a0fb98d181cdb677d3b5_Rectangle 151.png" loading="lazy" alt="" class="image-21"/></div><div class="process_card_tittle-wrapper"><div class="card_tittle_number">4</div><div class="card_tittle_text">Bàn giao &amp; đồng hành</div></div><div class="process_card_content">Sau khi hoàn thiện thiết kế tổng thể là lúc sản phẩm được lập trình, tinh chỉnh và kiểm thử kỹ lưỡng nhằm mang lại một giải pháp số hoàn chỉnh và sẵn sàng vận hành.</div></div></div></div></section><div class="about_section_feedback"><div class="padding-section-120"></div><div class="testimonial_wrapper"><div><div class="testimonial_text"><div class="button-text-wrapper"><div class="dot-on"></div><a data-wf-native-id-path="0dafb831-2247-ef41-41bf-e0ae017d5999" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="0dafb831-2247-ef41-41bf-e0ae017d5999" href="#" class="label-text w-button">đánh giá từ khách hàng</a></div></div><div class="testimonial_card-wrapper"><div data-w-id="0dafb831-2247-ef41-41bf-e0ae017d599c" style="opacity:0" class="testimonial_card style-line"><div class="review color-white">“One of those guys i know off don’t need the best equipment, a piece of paper can draw a landscape of awesomeness to impress the crowd.”</div><div class="testimonial_card_text-wrapper"><div class="div-block-48"><div class="div-block-17"><div class="text-block-7">Joe Zhou</div><a data-wf-native-id-path="4197bd68-6fbd-f41c-7b12-e1c1c3e806bc" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="4197bd68-6fbd-f41c-7b12-e1c1c3e806bc" href="https://www.linkedin.com/in/joehz/?lipi=urn%3Ali%3Apage%3Ad_flagship3_search_srp_all%3BWRfrGP3MQNK06U8ia1%2BAqQ%3D%3D" target="_blank" class="w-inline-block"><img src="/696db0cd2780ac54df960dfb/69805dedda39368fe35fee07_pixelarticons_external-link.png" loading="lazy" alt="" class="image-10"/></a></div><div class="text-block-6">CTO - The Martec </div></div><img src="/696db0cd2780ac54df960dfb/6989a2225fc7b7c1f3f01348_Layer 1.png" loading="lazy" width="Auto" alt="" class="image-11"/></div></div><div data-w-id="0dafb831-2247-ef41-41bf-e0ae017d59a8" style="opacity:0" class="testimonial_card style-line"><div class="review color-white">“Website chạm đúng đến giá trị cốt lõi của thương hiệu từ màu sắc, bố cục đến nội dung. Team S.Sens rất hài lòng khi nhận được sản phẩm cũng như cách làm việc của Dao.Design”<br/></div><div class="testimonial_card_text-wrapper"><div class="div-block-50"><div class="div-block-17"><div class="text-block-7">Thu HANG</div><img src="/696db0cd2780ac54df960dfb/69805dedda39368fe35fee07_pixelarticons_external-link.png" loading="lazy" alt="" class="image-10 display-none"/></div><div class="text-block-6">founder - S.Sens Homes</div></div><img src="/696db0cd2780ac54df960dfb/698068b7f44b747475aa2188_7ebe0dcdecc04837180128ae4fac540f_S.SENS logo final-13 2.png" loading="lazy" width="Auto" alt="" class="image-11"/></div></div></div></div></div><div class="padding-section-72"></div></div><section class="footer"><div class="carousel-wrapper"><div class="carousel"><div class="div-block-19"><div class="text-block-8">INSPIRE<br/></div><img src="data:image/png;base64," alt="Right" class="img"/><div class="text-block-8">DELIVERY</div><img src="data:image/png;base64," alt="Right" class="img"/></div><div class="div-block-19"><div class="text-block-8">CREATE<br/></div><img src="data:image/png;base64," alt="Right" class="img"/><div class="text-block-8">INSPIRE<br/></div><img src="data:image/png;base64," alt="Right" class="img"/></div><div class="div-block-19"><div class="text-block-8">DELIVERY</div><img src="data:image/png;base64," alt="Right" class="img"/><div class="text-block-8">CREATE</div><img src="data:image/png;base64," alt="Right" class="img"/></div></div><div class="carousel"><div class="div-block-19"><div class="text-block-8">INSPIRE<br/></div><img src="data:image/png;base64," alt="Right" class="img"/><div class="text-block-8">DELIVERY</div><img src="data:image/png;base64," alt="Right" class="img"/></div><div class="div-block-19"><div class="text-block-8">CREATE<br/></div><img src="data:image/png;base64," alt="Right" class="img"/><div class="text-block-8">INSPIRE<br/></div><img src="data:image/png;base64," alt="Right" class="img"/></div><div class="div-block-19"><div class="text-block-8">DELIVERY</div><img src="data:image/png;base64," alt="Right" class="img"/><div class="text-block-8">CREATE</div><img src="data:image/png;base64," alt="Right" class="img"/></div></div></div><div class="footer-wrapper"><div class="w-layout-blockcontainer footer_component-wrapper w-container"><div id="w-node-de562e6c-0f4a-79be-cdaf-34f4cba07b02-cba07ae4" class="footer_contact"><div class="div-block-20-copy"><img loading="lazy" src="/696db0cd2780ac54df960dfb/69807d7662ecd0c600bde722_pixelarticons_home.png" alt=""/><div class="text-block-9">based in Vietnam</div></div><a data-wf-native-id-path="38e09c9a-b849-52e6-2d34-a3d3411a88aa:b60b88af-2ab4-31d5-1d88-d3803b8cbf86" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="b60b88af-2ab4-31d5-1d88-d3803b8cbf86" data-wf-component-context="%5B%7B%22componentId%22%3A%22de562e6c-0f4a-79be-cdaf-34f4cba07ae4%22%2C%22instanceId%22%3A%2238e09c9a-b849-52e6-2d34-a3d3411a88aa%22%7D%5D" href="https://www.instagram.com/studio.daodesign/" target="_blank" class="link-block-7 w-inline-block"><div class="div-block-20-copy"><img loading="lazy" src="/696db0cd2780ac54df960dfb/69807d7600401fa19e13fe9a_pixel_instagram.png" alt=""/><div class="text-block-9">studio.daodesign</div></div></a><a data-wf-native-id-path="38e09c9a-b849-52e6-2d34-a3d3411a88aa:0722df4d-6687-c5e5-887a-107749e2e26b" data-wf-ao-click-engagement-tracking="true" data-wf-element-id="0722df4d-6687-c5e5-887a-107749e2e26b" data-wf-component-context="%5B%7B%22componentId%22%3A%22de56